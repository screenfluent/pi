{
  "name": "@e9n/pi-heartbeat",
  "version": "0.1.0",
  "description": "Periodic health check extension for pi — runs a heartbeat prompt as an isolated subprocess",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "author": "Espen Nilsen <hi@e9n.dev>",
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
