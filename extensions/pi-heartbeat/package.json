    "typescript": "^5.9.3"
  },
  "files": [
    "CHANGELOG.md",
    "README.md",
    "package.json",
    "skills",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/espennilsen/pi.git",
    "directory": "extensions/pi-heartbeat"
  }
}
